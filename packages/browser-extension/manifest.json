{
  "manifest_version": 3,
  "name": "LLM Output Guard",
  "description": "Detects and fixes broken Markdown code fences in LLM web responses.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "dist/contentScript.js"
      ],
      "css": [
        "dist/styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": []
}
